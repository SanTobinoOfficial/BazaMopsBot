# ── Discord Bot ───────────────────────────────────────────────────────────────
# Token bota z https://discord.com/developers/applications
DISCORD_TOKEN=twoj_token_tutaj

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Losowy ciąg znaków – klucz sesji Flask (wygeneruj np. przez: python -c "import secrets; print(secrets.token_hex(32))")
DASHBOARD_SECRET=zmien_na_losowy_ciag_znakow

# Hasło do dashboardu (wpisujesz je w oknie logowania)
DASHBOARD_PASSWORD=twoje_haslo_tutaj
